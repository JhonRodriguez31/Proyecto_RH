<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<HBox fx:id="authRoot" styleClass="auth-root" stylesheets="@../../css/auth-layout.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.controllers.AuthController">

    <VBox alignment="CENTER" minWidth="460" prefWidth="460" spacing="16" styleClass="auth-left-panel">
        <padding>
            <Insets bottom="40" left="40" right="40" top="40" />
        </padding>

        <FontIcon iconLiteral="mdi2s-shield-account-outline" styleClass="auth-brand-icon" />

        <Label styleClass="auth-brand-title" text="PlanillaCore" />

        <Label contentDisplay="CENTER" prefHeight="18.0" prefWidth="255.0" styleClass="auth-brand-subtitle" text="Sistema de Gestión de Recursos Humanos" textOverrun="CENTER_ELLIPSIS" />

        <Region maxHeight="1" maxWidth="200" prefHeight="1" styleClass="auth-brand-divider" />

        <Region minHeight="8" />

        <HBox styleClass="auth-brand-feature-row">
            <FontIcon iconLiteral="mdi2a-account-group-outline" styleClass="auth-feature-icon" />
            <Label styleClass="auth-feature-text" text="Gestión integral de empleados" />
        </HBox>

        <HBox styleClass="auth-brand-feature-row">
            <FontIcon iconLiteral="mdi2c-calendar-check-outline" styleClass="auth-feature-icon" />
            <Label styleClass="auth-feature-text" text="Control de asistencias y vacaciones" />
        </HBox>

        <HBox styleClass="auth-brand-feature-row">
            <FontIcon iconLiteral="mdi2c-cash-multiple" styleClass="auth-feature-icon" />
            <Label styleClass="auth-feature-text" text="Administración de planilla" />
        </HBox>

        <HBox styleClass="auth-brand-feature-row">
            <FontIcon iconLiteral="mdi2c-chart-bar" styleClass="auth-feature-icon" />
            <Label styleClass="auth-feature-text" text="Dashboard analítico en tiempo real" />
        </HBox>

        <Region VBox.vgrow="ALWAYS" />

        <Label styleClass="auth-version-badge" text="v1.0.0" />
    </VBox>

    <StackPane styleClass="auth-right-panel" HBox.hgrow="ALWAYS">

        <VBox alignment="CENTER" spacing="16">

            <VBox spacing="4" styleClass="auth-card">

                <Label styleClass="auth-card-title" text="Iniciar Sesión" />
                <Label styleClass="auth-card-subtitle" text="Ingresa tus credenciales para acceder al sistema" />

                <HBox fx:id="errorBox" managed="false" styleClass="auth-error-box" visible="false">
                    <FontIcon iconLiteral="mdi2a-alert-circle-outline" styleClass="auth-error-icon" />
                    <Label fx:id="errorLabel" styleClass="auth-error-text" text="Credenciales inválidas" />
                </HBox>

                <Label styleClass="auth-field-label" text="DNI" />
                <HBox styleClass="auth-input-wrapper">
                    <FontIcon iconLiteral="mdi2a-account-outline" styleClass="auth-input-icon" />
                    <TextField fx:id="usernameField" promptText="Ingresa tu DNI" styleClass="auth-text-field" HBox.hgrow="ALWAYS" />
                </HBox>

                <Label styleClass="auth-field-label" text="CONTRASEÑA" />
                <HBox styleClass="auth-input-wrapper">
                    <FontIcon iconLiteral="mdi2l-lock-outline" styleClass="auth-input-icon" />
                    <StackPane alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                        <PasswordField fx:id="passwordField" maxWidth="1.7976931348623157E308" promptText="Ingresa tu contraseña" styleClass="auth-password-field" />
                        <TextField fx:id="visiblePasswordField" managed="false" maxWidth="1.7976931348623157E308" promptText="Ingresa tu contraseña" styleClass="auth-text-field" visible="false" />
                    </StackPane>
                    <Button fx:id="togglePasswordBtn" onAction="#togglePasswordVisibility" styleClass="auth-toggle-password">
                        <graphic>
                            <FontIcon fx:id="togglePasswordIcon" iconLiteral="mdi2e-eye-outline" styleClass="auth-toggle-icon" />
                        </graphic>
                    </Button>
                </HBox>

                <Region minHeight="8" />

                <Button fx:id="loginButton" maxWidth="Infinity" onAction="#handleLogin" styleClass="auth-btn-primary" text="Iniciar Sesión">
                    <graphic>
                        <FontIcon iconLiteral="mdi2l-login" styleClass="auth-btn-icon" />
                    </graphic>
                </Button>

                <Region minHeight="4" />
                <HBox alignment="CENTER" spacing="0">
                    <Region styleClass="auth-divider-line" HBox.hgrow="ALWAYS" />
                    <Label styleClass="auth-divider-text" text="o" />
                    <Region styleClass="auth-divider-line" HBox.hgrow="ALWAYS" />
                </HBox>

                <HBox alignment="CENTER">
                    <Button fx:id="resetPasswordBtn" onAction="#handleResetPassword" styleClass="auth-link-btn" text="Restablecer Contraseña">
                        <graphic>
                            <FontIcon iconLiteral="mdi2l-lock-reset" styleClass="auth-link-icon" />
                        </graphic>
                    </Button>
                </HBox>
            </VBox>

            <Label styleClass="auth-footer-text" text="© 2026 PlanillaCore — Todos los derechos reservados" textFill="WHITE" />
        </VBox>
    </StackPane>
</HBox>
