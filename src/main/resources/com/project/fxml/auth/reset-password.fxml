<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<HBox fx:id="resetRoot" styleClass="auth-root" stylesheets="@../../css/auth-layout.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.controllers.ResetPasswordController">

    <VBox alignment="CENTER" minWidth="460" prefWidth="460" spacing="16" styleClass="auth-left-panel">
        <padding>
            <Insets bottom="40" left="40" right="40" top="40" />
        </padding>

        <FontIcon iconLiteral="mdi2s-shield-account-outline" styleClass="auth-brand-icon" />

        <Label styleClass="auth-brand-title" text="PlanillaCore" />

        <Label styleClass="auth-brand-subtitle" text="Sistema de Gestión de Recursos Humanos" />

        <Region maxHeight="1" maxWidth="200" prefHeight="1" styleClass="auth-brand-divider" />

        <Region minHeight="8" />

        <HBox styleClass="auth-brand-feature-row">
            <FontIcon iconLiteral="mdi2a-account-group-outline" styleClass="auth-feature-icon" />
            <Label styleClass="auth-feature-text" text="Gestión integral de empleados" />
        </HBox>

        <HBox styleClass="auth-brand-feature-row">
            <FontIcon iconLiteral="mdi2c-calendar-check-outline" styleClass="auth-feature-icon" />
            <Label styleClass="auth-feature-text" text="Control de asistencias y vacaciones" />
        </HBox>

        <HBox styleClass="auth-brand-feature-row">
            <FontIcon iconLiteral="mdi2c-cash-multiple" styleClass="auth-feature-icon" />
            <Label styleClass="auth-feature-text" text="Administración de planilla" />
        </HBox>

        <HBox styleClass="auth-brand-feature-row">
            <FontIcon iconLiteral="mdi2c-chart-bar" styleClass="auth-feature-icon" />
            <Label styleClass="auth-feature-text" text="Dashboard analítico en tiempo real" />
        </HBox>

        <Region VBox.vgrow="ALWAYS" />

        <Label styleClass="auth-version-badge" text="v1.0.0" />
    </VBox>

    <StackPane styleClass="auth-right-panel" HBox.hgrow="ALWAYS">

        <VBox alignment="CENTER" spacing="16">

            <VBox spacing="4" styleClass="auth-card">

                <HBox alignment="CENTER">
                    <StackPane styleClass="auth-reset-icon-circle">
                        <FontIcon iconLiteral="mdi2l-lock-reset" styleClass="auth-reset-big-icon" />
                    </StackPane>
                </HBox>

                <Region minHeight="4" />

                <Label style="-fx-alignment: CENTER;" styleClass="auth-card-title" text="Restablecer Contraseña" />
                <Label style="-fx-text-alignment: CENTER; -fx-alignment: CENTER;" styleClass="auth-card-subtitle" text="Ingresa tu dni para recibir instrucciones de restablecimiento" wrapText="true" />

                <HBox fx:id="successBox" managed="false" styleClass="auth-success-box" visible="false">
                    <FontIcon iconLiteral="mdi2c-check-circle-outline" styleClass="auth-success-icon" />
                    <Label fx:id="successLabel" styleClass="auth-success-text" text="Instrucciones enviadas correctamente" />
                </HBox>

                <HBox fx:id="errorBox" managed="false" styleClass="auth-error-box" visible="false">
                    <FontIcon iconLiteral="mdi2a-alert-circle-outline" styleClass="auth-error-icon" />
                    <Label fx:id="errorLabel" styleClass="auth-error-text" text="" />
                </HBox>

                <!-- Username field -->
                <Label styleClass="auth-field-label" text="DNI" />
                <HBox styleClass="auth-input-wrapper">
                    <FontIcon iconLiteral="mdi2a-account-outline" styleClass="auth-input-icon" />
                    <TextField fx:id="usernameField" promptText="Ingresa tu dni" styleClass="auth-text-field" HBox.hgrow="ALWAYS" />
                </HBox>

                <Region minHeight="8" />

                <Button fx:id="resetButton" maxWidth="Infinity" onAction="#handleReset" styleClass="auth-btn-primary" text="Enviar Instrucciones">
                    <graphic>
                        <FontIcon iconLiteral="mdi2e-email-send-outline" styleClass="auth-btn-icon" />
                    </graphic>
                </Button>

                <Region minHeight="4" />
                <HBox alignment="CENTER" spacing="0">
                    <Region styleClass="auth-divider-line" HBox.hgrow="ALWAYS" />
                    <Label styleClass="auth-divider-text" text="o" />
                    <Region styleClass="auth-divider-line" HBox.hgrow="ALWAYS" />
                </HBox>

                <HBox alignment="CENTER">
                    <Button fx:id="backToLoginBtn" onAction="#handleBackToLogin" styleClass="auth-link-btn" text="Volver a Iniciar Sesión">
                        <graphic>
                            <FontIcon iconLiteral="mdi2a-arrow-left" styleClass="auth-link-icon" />
                        </graphic>
                    </Button>
                </HBox>
            </VBox>

            <Label styleClass="auth-footer-text" text="© 2026 PlanillaCore — Todos los derechos reservados" />
        </VBox>
    </StackPane>
</HBox>
