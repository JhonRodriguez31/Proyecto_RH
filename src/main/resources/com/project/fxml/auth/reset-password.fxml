<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox fx:id="resetRoot"
      styleClass="auth-root"
      stylesheets="@../../css/auth-layout.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.controllers.ResetPasswordController">

    <VBox styleClass="auth-left-panel"
          prefWidth="460"
          minWidth="460"
          spacing="16"
          alignment="CENTER">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <FontIcon iconLiteral="mdi2s-shield-account-outline"
                  styleClass="auth-brand-icon"/>

        <Label text="PlanillaCore"
               styleClass="auth-brand-title"/>

        <Label text="Sistema de Gestión de Recursos Humanos"
               styleClass="auth-brand-subtitle"/>

        <Region styleClass="auth-brand-divider"
                maxWidth="200"
                prefHeight="1"
                maxHeight="1"/>

        <Region minHeight="8"/>

        <HBox styleClass="auth-brand-feature-row">
            <FontIcon iconLiteral="mdi2a-account-group-outline"
                      styleClass="auth-feature-icon"/>
            <Label text="Gestión integral de empleados"
                   styleClass="auth-feature-text"/>
        </HBox>

        <HBox styleClass="auth-brand-feature-row">
            <FontIcon iconLiteral="mdi2c-calendar-check-outline"
                      styleClass="auth-feature-icon"/>
            <Label text="Control de asistencias y vacaciones"
                   styleClass="auth-feature-text"/>
        </HBox>

        <HBox styleClass="auth-brand-feature-row">
            <FontIcon iconLiteral="mdi2c-cash-multiple"
                      styleClass="auth-feature-icon"/>
            <Label text="Administración de planilla"
                   styleClass="auth-feature-text"/>
        </HBox>

        <HBox styleClass="auth-brand-feature-row">
            <FontIcon iconLiteral="mdi2c-chart-bar"
                      styleClass="auth-feature-icon"/>
            <Label text="Dashboard analítico en tiempo real"
                   styleClass="auth-feature-text"/>
        </HBox>

        <Region VBox.vgrow="ALWAYS"/>

        <Label text="v1.0.0"
               styleClass="auth-version-badge"/>
    </VBox>

    <StackPane styleClass="auth-right-panel"
               HBox.hgrow="ALWAYS">

        <VBox alignment="CENTER"
              spacing="16">

            <VBox styleClass="auth-card"
                  spacing="4">

                <HBox alignment="CENTER">
                    <StackPane styleClass="auth-reset-icon-circle">
                        <FontIcon iconLiteral="mdi2l-lock-reset"
                                  styleClass="auth-reset-big-icon"/>
                    </StackPane>
                </HBox>

                <Region minHeight="4"/>

                <Label text="Restablecer Contraseña"
                       styleClass="auth-card-title"
                       style="-fx-alignment: CENTER;"/>
                <Label text="Ingresa tu nombre de usuario para recibir instrucciones de restablecimiento"
                       styleClass="auth-card-subtitle"
                       wrapText="true"
                       style="-fx-text-alignment: CENTER; -fx-alignment: CENTER;"/>

                <HBox fx:id="successBox"
                      styleClass="auth-success-box"
                      visible="false"
                      managed="false">
                    <FontIcon iconLiteral="mdi2c-check-circle-outline"
                              styleClass="auth-success-icon"/>
                    <Label fx:id="successLabel"
                           text="Instrucciones enviadas correctamente"
                           styleClass="auth-success-text"/>
                </HBox>

                <HBox fx:id="errorBox"
                      styleClass="auth-error-box"
                      visible="false"
                      managed="false">
                    <FontIcon iconLiteral="mdi2a-alert-circle-outline"
                              styleClass="auth-error-icon"/>
                    <Label fx:id="errorLabel"
                           text=""
                           styleClass="auth-error-text"/>
                </HBox>

                <!-- Username field -->
                <Label text="USUARIO"
                       styleClass="auth-field-label"/>
                <HBox styleClass="auth-input-wrapper">
                    <FontIcon iconLiteral="mdi2a-account-outline"
                              styleClass="auth-input-icon"/>
                    <TextField fx:id="usernameField"
                               promptText="Ingresa tu nombre de usuario"
                               styleClass="auth-text-field"
                               HBox.hgrow="ALWAYS"/>
                </HBox>

                <Region minHeight="8"/>

                <Button fx:id="resetButton"
                        text="Enviar Instrucciones"
                        maxWidth="Infinity"
                        styleClass="auth-btn-primary"
                        onAction="#handleReset">
                    <graphic>
                        <FontIcon iconLiteral="mdi2e-email-send-outline"
                                  styleClass="auth-btn-icon"/>
                    </graphic>
                </Button>

                <Region minHeight="4"/>
                <HBox alignment="CENTER"
                      spacing="0">
                    <Region styleClass="auth-divider-line"
                            HBox.hgrow="ALWAYS"/>
                    <Label text="o"
                           styleClass="auth-divider-text"/>
                    <Region styleClass="auth-divider-line"
                            HBox.hgrow="ALWAYS"/>
                </HBox>

                <HBox alignment="CENTER">
                    <Button fx:id="backToLoginBtn"
                            text="Volver a Iniciar Sesión"
                            styleClass="auth-link-btn"
                            onAction="#handleBackToLogin">
                        <graphic>
                            <FontIcon iconLiteral="mdi2a-arrow-left"
                                      styleClass="auth-link-icon"/>
                        </graphic>
                    </Button>
                </HBox>
            </VBox>

            <Label text="© 2026 PlanillaCore — Todos los derechos reservados"
                   styleClass="auth-footer-text"/>
        </VBox>
    </StackPane>
</HBox>
