<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<HBox fx:id="changeRoot" styleClass="auth-root" stylesheets="@../../css/auth-layout.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.controllers.ChangePasswordController">

    <VBox alignment="CENTER" minWidth="460" prefWidth="460" spacing="16" styleClass="auth-left-panel">
        <padding>
            <Insets bottom="40" left="40" right="40" top="40" />
        </padding>

        <FontIcon iconLiteral="mdi2s-shield-account-outline" styleClass="auth-brand-icon" />
        <Label styleClass="auth-brand-title" text="PlanillaCore" />
        <Label styleClass="auth-brand-subtitle" text="Sistema de Gestión de Recursos Humanos" />
        <Region maxHeight="1" maxWidth="200" prefHeight="1" styleClass="auth-brand-divider" />
        <Region minHeight="8" />

        <HBox styleClass="auth-brand-feature-row">
            <FontIcon iconLiteral="mdi2a-account-group-outline" styleClass="auth-feature-icon" />
            <Label styleClass="auth-feature-text" text="Gestión integral de empleados" />
        </HBox>
        <HBox styleClass="auth-brand-feature-row">
            <FontIcon iconLiteral="mdi2c-calendar-check-outline" styleClass="auth-feature-icon" />
            <Label styleClass="auth-feature-text" text="Control de asistencias y vacaciones" />
        </HBox>
        <HBox styleClass="auth-brand-feature-row">
            <FontIcon iconLiteral="mdi2c-cash-multiple" styleClass="auth-feature-icon" />
            <Label styleClass="auth-feature-text" text="Administración de planilla" />
        </HBox>
        <HBox styleClass="auth-brand-feature-row">
            <FontIcon iconLiteral="mdi2c-chart-bar" styleClass="auth-feature-icon" />
            <Label styleClass="auth-feature-text" text="Dashboard analítico en tiempo real" />
        </HBox>

        <Region VBox.vgrow="ALWAYS" />
        <Label styleClass="auth-version-badge" text="v1.0.0" />
    </VBox>

    <StackPane styleClass="auth-right-panel" HBox.hgrow="ALWAYS">
        <VBox alignment="CENTER" spacing="16">
            <VBox spacing="4" styleClass="auth-card">
                <HBox alignment="CENTER">
                    <StackPane styleClass="auth-reset-icon-circle" style="-fx-background-color: #6366f1;">
                        <FontIcon iconLiteral="mdi2l-lock-check" styleClass="auth-reset-big-icon" style="-fx-icon-color: white;" />
                    </StackPane>
                </HBox>

                <Region minHeight="4" />
                <Label style="-fx-alignment: CENTER;" styleClass="auth-card-title" text="Actualizar Contraseña" />
                <Label style="-fx-text-alignment: CENTER; -fx-alignment: CENTER;" styleClass="auth-card-subtitle" text="Es tu primera vez en el sistema. Por seguridad, debes cambiar tu contraseña temporal." wrapText="true" />

                <HBox fx:id="errorBox" managed="false" styleClass="auth-error-box" visible="false">
                    <FontIcon iconLiteral="mdi2a-alert-circle-outline" styleClass="auth-error-icon" />
                    <Label fx:id="errorLabel" styleClass="auth-error-text" text="" />
                </HBox>

                <Label styleClass="auth-field-label" text="Nueva Contraseña" />
                <HBox styleClass="auth-input-wrapper">
                    <FontIcon iconLiteral="mdi2l-lock-outline" styleClass="auth-input-icon" />
                    <PasswordField fx:id="newPasswordField" promptText="Mínimo 8 caracteres" styleClass="auth-text-field" HBox.hgrow="ALWAYS" />
                </HBox>

                <Label styleClass="auth-field-label" text="Confirmar Contraseña" />
                <HBox styleClass="auth-input-wrapper">
                    <FontIcon iconLiteral="mdi2l-lock-check-outline" styleClass="auth-input-icon" />
                    <PasswordField fx:id="confirmPasswordField" promptText="Repite tu nueva contraseña" styleClass="auth-text-field" HBox.hgrow="ALWAYS" />
                </HBox>

                <Region minHeight="12" />

                <Button fx:id="changeBtn" maxWidth="Infinity" onAction="#handleChangePassword" styleClass="auth-btn-primary" text="Actualizar y Entrar">
                    <graphic>
                        <FontIcon iconLiteral="mdi2c-check-bold" styleClass="auth-btn-icon" />
                    </graphic>
                </Button>
            </VBox>

            <Label styleClass="auth-footer-text" text="© 2026 PlanillaCore — Todos los derechos reservados" textFill="WHITE" />
        </VBox>
    </StackPane>
</HBox>
