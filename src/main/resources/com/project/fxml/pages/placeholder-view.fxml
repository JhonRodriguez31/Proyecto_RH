<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15"
      styleClass="page-container"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.controllers.EmpleadoController">
    <padding>
        <Insets top="20"
                right="20"
                bottom="20"
                left="20"/>
    </padding>

    <!-- Sección de Foto -->
    <Label text="Subir Foto de Empleado"
           styleClass="section-title"/>

    <VBox spacing="10"
          style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15;">
        <ImageView
                fx:id="fotoPreview"
                fitWidth="200"
                fitHeight="200"
                preserveRatio="true"
                style="-fx-border-color: #dddddd; -fx-border-radius: 5;"/>

        <HBox spacing="10">
            <Button fx:id="btnSeleccionarFoto"
                    text="Seleccionar Foto"
                    onAction="#seleccionarFoto"
                    style="-fx-padding: 8; -fx-font-size: 12;"/>

            <Button fx:id="btnEliminarFoto"
                    text="Eliminar Foto"
                    onAction="#eliminarFoto"
                    style="-fx-padding: 8; -fx-font-size: 12; -fx-text-fill: white; -fx-background-color: #ff4444;"/>

            <Button fx:id="btnSubirFoto"
                    text="Subir Foto"
                    onAction="#subirFoto"
                    style="-fx-padding: 8; -fx-font-size: 12; -fx-text-fill: white; -fx-background-color: #44aa44;"/>
        </HBox>

        <Label fx:id="statusLabel"
               text="Selecciona una imagen..."
               style="-fx-text-fill: #666666;"/>
    </VBox>

</VBox>