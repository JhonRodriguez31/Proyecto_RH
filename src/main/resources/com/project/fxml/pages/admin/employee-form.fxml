<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="20"
      styleClass="form-container"
      stylesheets="@../../../css/theme.css, @../../../css/styles.css, @../../../css/empleado.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.controllers.EmpleadoFormController">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <VBox spacing="5">
        <Label fx:id="titleLabel" text="Nuevo Empleado" styleClass="form-title"/>
        <Label text="Complete la información del empleado" styleClass="form-subtitle"/>
    </VBox>

    <HBox spacing="20" alignment="CENTER_LEFT" styleClass="image-upload-section">
        <StackPane styleClass="profile-avatar-wrapper">
            <ImageView fx:id="imgPerfil" fitWidth="100" fitHeight="100" preserveRatio="false" />
            <Label fx:id="lblAvatarInicial" text="?" styleClass="profile-avatar-initial" />
        </StackPane>
        <VBox spacing="8" alignment="CENTER_LEFT">
            <Button fx:id="btnCambiarFoto" text="Seleccionar Foto" styleClass="btn-secondary" onAction="#seleccionarFoto">
                <graphic>
                    <FontIcon iconLiteral="mdi2c-camera" />
                </graphic>
            </Button>
            <Label fx:id="lblUploadStatus" text="Sin foto seleccionada" style="-fx-text-fill: -fx-text-secondary; -fx-font-size: 11px;"/>
        </VBox>
    </HBox>

    <GridPane hgap="18" vgap="18">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="50" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="50" />
        </columnConstraints>

        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <Label text="Código de Empleado"/>
            <TextField fx:id="txtCodigo" promptText="Auto-generado" editable="false"
                       style="-fx-opacity: 0.7;"/>
        </VBox>

        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <Label text="DNI (8 dígitos)"/>
            <TextField fx:id="txtDni" promptText="Ej: 71234567"/>
        </VBox>

        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1">
            <Label text="Nombres"/>
            <TextField fx:id="txtNombres" promptText="Ej: Juan Carlos"/>
        </VBox>

        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <Label text="Apellidos"/>
            <TextField fx:id="txtApellidos" promptText="Ej: Pérez López"/>
        </VBox>

        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="2">
            <Label text="Correo Electrónico"/>
            <TextField fx:id="txtEmail" promptText="Ej: juan.perez@empresa.com"/>
        </VBox>

        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="2">
            <Label text="Teléfono (9 dígitos)"/>
            <TextField fx:id="txtTelefono" promptText="Ej: 987654321"/>
        </VBox>

        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="3">
            <Label text="Estado"/>
            <ComboBox fx:id="cbEstado" maxWidth="Infinity"/>
        </VBox>

        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="3">
            <Label text="Fecha de Nacimiento"/>
            <DatePicker fx:id="dpFechaNacimiento" maxWidth="Infinity"/>
        </VBox>

        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="4">
            <Label text="Fecha de Ingreso"/>
            <DatePicker fx:id="dpFechaIngreso" maxWidth="Infinity"/>
        </VBox>

        <VBox spacing="6" GridPane.columnSpan="2" GridPane.rowIndex="5">
            <Label text="Dirección"/>
            <TextField fx:id="txtDireccion" promptText="Ej: Av. Javier Prado 1234, Lima"/>
        </VBox>
    </GridPane>

    <Region VBox.vgrow="ALWAYS"/>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button fx:id="btnCancelar" text="Cancelar" styleClass="btn-secondary"/>
        <Button fx:id="btnGuardar" text="Guardar Empleado" styleClass="btn-primary">
            <graphic>
                <FontIcon iconLiteral="mdi2c-check" style="-fx-icon-color: white; -fx-icon-size: 16;"/>
            </graphic>
        </Button>
    </HBox>

</VBox>
