<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" stylesheets="@../../../css/styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.controllers.DashboardController">
    <content>
        <VBox spacing="25.0" styleClass="dashboard-container">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <VBox spacing="5.0">
                    <children>
                        <Label styleClass="dashboard-title" text="Dashboard de Gestión Humana" />
                        <Label styleClass="dashboard-subtitle" text="Resumen ejecutivo del estado de los colaboradores" />
                    </children>
                </VBox>

                <!-- Statistics Tiles Container -->
                <FlowPane fx:id="tilesContainer" hgap="20.0" vgap="20.0" />

                <!-- Charts Container -->
                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox styleClass="chart-card" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                            <children>
                                <Label styleClass="chart-title" text="Colaboradores por Área" />
                                <PieChart fx:id="areaChart" legendSide="RIGHT" prefHeight="400.0" />
                            </children>
                        </VBox>

                        <VBox styleClass="chart-card" HBox.hgrow="ALWAYS">
                            <padding>
                                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                            </padding>
                            <children>
                                <Label styleClass="chart-title" text="Asistencia del Día" />
                                <BarChart fx:id="attendanceChart" prefHeight="400.0">
                                    <xAxis>
                                        <CategoryAxis side="BOTTOM" />
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis side="LEFT" />
                                    </yAxis>
                                </BarChart>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
