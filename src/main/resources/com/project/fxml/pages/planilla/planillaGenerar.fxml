<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox spacing="20"
      styleClass="planilla-root"
      stylesheets="@../../../css/theme.css, @../../../css/styles.css, @../../../css/empleado.css, @../../../css/planilla.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.controllers.PlanillaGenerarController">

    <!-- ══ COLUMNA IZQUIERDA: FORMULARIO ══════════════════════ -->
    <VBox spacing="18" prefWidth="600" styleClass="planilla-card">

        <VBox spacing="5">
            <Label text="Generar Planilla" styleClass="planilla-title"/>
            <Label text="Completa los datos y presiona Calcular para previsualizar." styleClass="planilla-subtitle"/>
        </VBox>

        <!-- Empleado -->
        <VBox spacing="4" styleClass="form-container">
            <Label text="Empleado *" styleClass="planilla-label"/>
            <ComboBox fx:id="cbEmpleado" maxWidth="Infinity" promptText="Seleccionar empleado"/>
        </VBox>

        <!-- Periodo -->
        <HBox spacing="12" styleClass="form-container">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Mes *" styleClass="planilla-label"/>
                <ComboBox fx:id="cbMes" maxWidth="Infinity"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Año *" styleClass="planilla-label"/>
                <ComboBox fx:id="cbAnio" maxWidth="Infinity"/>
            </VBox>
        </HBox>

        <!-- Deducciones opcionales -->
        <HBox spacing="12" styleClass="form-container">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Minutos de tardanza" styleClass="planilla-label"/>
                <TextField fx:id="txtMinutosTardanza" promptText="0"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Días de falta" styleClass="planilla-label"/>
                <TextField fx:id="txtDiasFalta" promptText="0"/>
            </VBox>
        </HBox>

        <Button text="Calcular Planilla"
                maxWidth="Infinity"
                prefHeight="40"
                styleClass="btn-calc"
                onAction="#calcular">
            <graphic><FontIcon iconLiteral="mdi2c-calculator" style="-fx-icon-color:white; -fx-icon-size:16;"/></graphic>
        </Button>

        <Separator/>

        <!-- Tabla de detalle -->
        <Label text="Detalle calculado" styleClass="planilla-title" style="-fx-font-size: 15px;"/>

        <StackPane VBox.vgrow="ALWAYS" styleClass="table-container-vintage">
            <TableView fx:id="tablaDetalle" prefHeight="220" styleClass="modern-table">
                <columns>
                    <TableColumn fx:id="colConcepto"    text="Concepto"     prefWidth="130"/>
                    <TableColumn fx:id="colTipo"        text="Tipo"         prefWidth="90"/>
                    <TableColumn fx:id="colDescripcion" text="Descripción"  prefWidth="220"/>
                    <TableColumn fx:id="colMonto"       text="Monto"        prefWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="Presiona Calcular para ver el detalle" styleClass="planilla-subtitle"/>
                </placeholder>
            </TableView>
        </StackPane>

    </VBox>

    <!-- ══ COLUMNA DERECHA: RESUMEN Y GUARDAR ══════════════════ -->
    <VBox spacing="16" prefWidth="260" styleClass="planilla-card">

        <Label text="Resumen" styleClass="planilla-title" style="-fx-font-size: 20px;"/>

        <Separator/>

        <HBox>
            <Label text="Total Ingresos" styleClass="planilla-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblIngresos" text="S/ 0.00" styleClass="text-ingreso" style="-fx-font-size: 14px;"/>
        </HBox>

        <HBox>
            <Label text="Total Descuentos" styleClass="planilla-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblDescuentos" text="S/ 0.00" styleClass="text-descuento" style="-fx-font-size: 14px;"/>
        </HBox>

        <Separator/>

        <!-- Neto -->
        <VBox spacing="6" alignment="CENTER" styleClass="neto-panel">
            <Label text="Neto a Pagar" styleClass="neto-panel-title"/>
            <Label fx:id="lblNeto" text="S/ 0.00" styleClass="neto-panel-amount"/>
        </VBox>

        <Region VBox.vgrow="ALWAYS"/>

        <Button fx:id="btnGuardar"
                text="Guardar Planilla"
                maxWidth="Infinity"
                prefHeight="44"
                styleClass="btn-save-success"
                onAction="#guardarPlanilla">
            <graphic><FontIcon iconLiteral="mdi2c-content-save" style="-fx-icon-color:white; -fx-icon-size:16;"/></graphic>
        </Button>

        <Button text="Cancelar"
                maxWidth="Infinity"
                prefHeight="38"
                styleClass="btn-outline"
                onAction="#cerrar"/>

    </VBox>

</HBox>
