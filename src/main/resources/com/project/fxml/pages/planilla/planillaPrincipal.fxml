<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="14" stylesheets="@../../../css/empleado.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.controllers.PlanillaPrincipalController">

    <padding>
        <Insets bottom="14" left="22" right="22" top="22" />
    </padding>

    <!-- ══ ENCABEZADO ══════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label styleClass="section-title" text="Gestión de Planillas" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnRecargar" onAction="#recargar" styleClass="btn-icon">
            <graphic><FontIcon iconLiteral="mdi2r-refresh" styleClass="icon-btn" /></graphic>
            <tooltip><Tooltip text="Recargar" /></tooltip>
        </Button>
        <Button onAction="#abrirGenerarPlanilla" styleClass="btn-primary" text="+ Generar Planilla">
            <graphic><FontIcon iconLiteral="mdi2p-plus" styleClass="icon-btn" /></graphic>
        </Button>
    </HBox>

    <!-- ══ FILTROS ════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color:white; -fx-padding:12 16;                  -fx-background-radius:10; -fx-border-radius:10;                  -fx-border-color:#E5E7EB;">

        <VBox spacing="3">
            <Label style="-fx-font-size:12px; -fx-text-fill:#6B7280;" text="Periodo" />
            <ComboBox fx:id="cbPeriodo" onAction="#aplicarFiltros" prefWidth="148" promptText="Todos" />
        </VBox>
        <VBox spacing="3">
            <Label style="-fx-font-size:12px; -fx-text-fill:#6B7280;" text="Empleado" />
            <ComboBox fx:id="cbEmpleado" onAction="#aplicarFiltros" prefWidth="200" promptText="Todos" />
        </VBox>
        <VBox spacing="3">
            <Label style="-fx-font-size:12px; -fx-text-fill:#6B7280;" text="Estado" />
            <ComboBox fx:id="cbEstado" onAction="#aplicarFiltros" prefWidth="138" promptText="Todos" />
        </VBox>
        <VBox spacing="3">
            <Label style="-fx-font-size:12px;" text=" " />
            <Button onAction="#limpiarFiltros" style="-fx-background-color:#F3F4F6; -fx-border-color:#D1D5DB;                            -fx-background-radius:6; -fx-border-radius:6; -fx-padding:5 14;" text="Limpiar" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <VBox spacing="3">
            <Label style="-fx-font-size:12px;" text=" " />
            <Button onAction="#eliminarPlanillaSeleccionada" styleClass="btn-danger" text="Eliminar seleccionada">
                <graphic><FontIcon iconLiteral="mdi2t-trash-can" styleClass="icon-btn" /></graphic>
            </Button>
        </VBox>
    </HBox>

    <!-- ══ TABLA PRINCIPAL ════════════════════════════════════ -->
    <TableView fx:id="tablaPlanillas" styleClass="empleados-table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colEmpleado" prefWidth="210" text="Empleado" />
            <TableColumn fx:id="colPeriodo" prefWidth="100" text="Periodo" />
            <TableColumn fx:id="colFecha" prefWidth="145" text="Fecha generación" />
            <TableColumn fx:id="colSueldo" prefWidth="120" text="Sueldo base" />
            <TableColumn fx:id="colEstado" prefWidth="110" text="Estado" />
        </columns>
        <placeholder><Label text="No hay planillas que coincidan con los filtros" /></placeholder>
    </TableView>

    <!-- ══ SECCIÓN DETALLE ════════════════════════════════════ -->
    <VBox spacing="10" style="-fx-background-color:white; -fx-padding:16;                  -fx-background-radius:10; -fx-border-radius:10;                  -fx-border-color:#E5E7EB;">

        <!-- Título + badge -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label style="-fx-font-size:15px; -fx-font-weight:bold;" text="Detalle de la planilla seleccionada" />
            <Label fx:id="lblBadgePlanilla" style="-fx-background-color:#EFF6FF; -fx-text-fill:#2563EB;                           -fx-padding:3 12; -fx-background-radius:20; -fx-font-size:12px;" text="" />
        </HBox>

        <!-- Dos columnas: INGRESOS | DESCUENTOS -->
        <HBox spacing="14">

            <!-- INGRESOS -->
            <VBox prefHeight="215.0" prefWidth="462.0" spacing="6" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label style="-fx-font-size:13px; -fx-font-weight:bold;                                   -fx-text-fill:#16A34A;" text="● INGRESOS" />
                </HBox>
                <TableView fx:id="tablaIngresos" prefHeight="183.0" prefWidth="462.0" styleClass="empleados-table">
                    <columns>
                        <TableColumn fx:id="colIngConcepto" prefWidth="130" text="Concepto" />
                        <TableColumn fx:id="colIngDescripcion" prefWidth="220" text="Descripción" />
                        <TableColumn fx:id="colIngMonto" prefWidth="110" text="Monto" />
                    </columns>
                    <placeholder>
                        <Label style="-fx-text-fill:#6B7280;" text="Sin ingresos" />
                    </placeholder>
                </TableView>
            </VBox>

            <!-- DESCUENTOS -->
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label style="-fx-font-size:13px; -fx-font-weight:bold;                                   -fx-text-fill:#DC2626;" text="● DESCUENTOS" />
                </HBox>
                <TableView fx:id="tablaDescuentos" prefHeight="150" styleClass="empleados-table">
                    <columns>
                        <TableColumn fx:id="colDescConcepto" prefWidth="130" text="Concepto" />
                        <TableColumn fx:id="colDescDescripcion" prefWidth="220" text="Descripción" />
                        <TableColumn fx:id="colDescMonto" prefWidth="110" text="Monto" />
                    </columns>
                    <placeholder>
                        <Label style="-fx-text-fill:#6B7280;" text="Sin descuentos" />
                    </placeholder>
                </TableView>
            </VBox>

        </HBox>

        <!-- ── Totales ──────────────────────────────────────── -->
        <HBox alignment="CENTER_RIGHT" spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-background-color:#F0FDF4; -fx-padding:8 18;                          -fx-background-radius:8 0 0 8;                          -fx-border-color:#BBF7D0; -fx-border-width:1;">
                <Label style="-fx-font-size:13px; -fx-text-fill:#166534;" text="Total ingresos:" />
                <Label fx:id="lblTotalIngresos" style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#16A34A;" text="S/ 0.00" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-background-color:#FEF2F2; -fx-padding:8 18;                          -fx-border-color:#FECACA; -fx-border-width:1 1 1 0;">
                <Label style="-fx-font-size:13px; -fx-text-fill:#991B1B;" text="Total descuentos:" />
                <Label fx:id="lblTotalDescuentos" style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#DC2626;" text="S/ 0.00" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-background-color:#EFF6FF; -fx-padding:8 18;                          -fx-background-radius:0 8 8 0;                          -fx-border-color:#BFDBFE; -fx-border-width:1 1 1 0;">
                <Label style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#1E40AF;" text="Neto a pagar:" />
                <Label fx:id="lblNeto" style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#2563EB;" text="S/ 0.00" />
            </HBox>
        </HBox>

    </VBox>

</VBox>
