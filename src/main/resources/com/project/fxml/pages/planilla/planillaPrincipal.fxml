<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="14" styleClass="planilla-root" stylesheets="@../../../css/theme.css, @../../../css/styles.css, @../../../css/empleado.css, @../../../css/planilla.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.controllers.PlanillaPrincipalController">

    <padding>
        <Insets bottom="14" left="22" right="22" top="22" />
    </padding>

    <!-- ══ ENCABEZADO ══════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <VBox spacing="5">
            <Label styleClass="page-title" text="Gestión de Planillas" />
            <Label text="Genera y revisa las planillas de pago de tus colaboradores" styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnRecargar" onAction="#recargar" styleClass="btn-action-vintage">
            <graphic><FontIcon iconLiteral="mdi2r-refresh" styleClass="icon-accent" iconSize="20" /></graphic>
            <tooltip><Tooltip text="Recargar" /></tooltip>
        </Button>
        <Button onAction="#abrirGenerarPlanilla" styleClass="btn-primary-vintage" text="NUEVA PLANILLA">
            <graphic><FontIcon iconLiteral="mdi2p-plus" iconSize="18" iconColor="white"/></graphic>
        </Button>
    </HBox>

    <!-- ══ FILTROS ════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="planilla-filter-bar">

        <VBox spacing="3" styleClass="form-container">
            <Label styleClass="planilla-label" text="Periodo" />
            <ComboBox fx:id="cbPeriodo" onAction="#aplicarFiltros" prefWidth="148" promptText="Todos" />
        </VBox>
        <VBox spacing="3" styleClass="form-container">
            <Label styleClass="planilla-label" text="Empleado" />
            <ComboBox fx:id="cbEmpleado" onAction="#aplicarFiltros" prefWidth="200" promptText="Todos" />
        </VBox>
        <VBox spacing="3" styleClass="form-container">
            <Label styleClass="planilla-label" text="Estado" />
            <ComboBox fx:id="cbEstado" onAction="#aplicarFiltros" prefWidth="138" promptText="Todos" />
        </VBox>
        <VBox spacing="3" styleClass="form-container">
            <Label styleClass="planilla-label" text=" " />
            <Button onAction="#limpiarFiltros" styleClass="btn-secondary" text="Limpiar" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <VBox spacing="3">
            <Label styleClass="planilla-label" text=" " />
            <Button onAction="#eliminarPlanillaSeleccionada" styleClass="btn-delete-vintage" text="ELIMINAR SELECCIONADA">
                <graphic><FontIcon iconLiteral="mdi2t-trash-can" iconSize="16" styleClass="icon-danger"/></graphic>
            </Button>
        </VBox>
    </HBox>

    <!-- ══ TABLA PRINCIPAL ════════════════════════════════════ -->
    <StackPane VBox.vgrow="ALWAYS" styleClass="table-container-vintage">
        <TableView fx:id="tablaPlanillas" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="colEmpleado" prefWidth="210" text="Empleado" />
                <TableColumn fx:id="colPeriodo" prefWidth="100" text="Periodo" />
                <TableColumn fx:id="colFecha" prefWidth="145" text="Fecha generación" />
                <TableColumn fx:id="colSueldo" prefWidth="120" text="Sueldo base" />
                <TableColumn fx:id="colEstado" prefWidth="110" text="Estado" />
            </columns>
            <placeholder><Label text="No hay planillas que coincidan con los filtros" styleClass="planilla-subtitle" /></placeholder>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </StackPane>

    <!-- ══ SECCIÓN DETALLE ════════════════════════════════════ -->
    <VBox spacing="10" styleClass="planilla-card">

        <!-- Título + badge -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label styleClass="planilla-title" style="-fx-font-size: 15px;" text="Detalle de la planilla seleccionada" />
            <Label fx:id="lblBadgePlanilla" styleClass="badge-info" text="" />
        </HBox>

        <!-- Dos columnas: INGRESOS | DESCUENTOS -->
        <HBox spacing="14">

            <!-- INGRESOS -->
            <VBox prefHeight="215.0" prefWidth="462.0" spacing="6" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label styleClass="text-ingreso" style="-fx-font-size: 13px;" text="● INGRESOS" />
                </HBox>
                <StackPane VBox.vgrow="ALWAYS" styleClass="table-container-vintage">
                    <TableView fx:id="tablaIngresos" prefHeight="183.0" prefWidth="462.0" styleClass="modern-table">
                        <columns>
                            <TableColumn fx:id="colIngConcepto" prefWidth="130" text="Concepto" />
                            <TableColumn fx:id="colIngDescripcion" prefWidth="220" text="Descripción" />
                            <TableColumn fx:id="colIngMonto" prefWidth="110" text="Monto" />
                        </columns>
                        <placeholder>
                            <Label styleClass="planilla-subtitle" text="Sin ingresos" />
                        </placeholder>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </StackPane>
            </VBox>

            <!-- DESCUENTOS -->
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label styleClass="text-descuento" style="-fx-font-size: 13px;" text="● DESCUENTOS" />
                </HBox>
                <StackPane VBox.vgrow="ALWAYS" styleClass="table-container-vintage">
                    <TableView fx:id="tablaDescuentos" prefHeight="150" styleClass="modern-table">
                        <columns>
                            <TableColumn fx:id="colDescConcepto" prefWidth="130" text="Concepto" />
                            <TableColumn fx:id="colDescDescripcion" prefWidth="220" text="Descripción" />
                            <TableColumn fx:id="colDescMonto" prefWidth="110" text="Monto" />
                        </columns>
                        <placeholder>
                            <Label styleClass="planilla-subtitle" text="Sin descuentos" />
                        </placeholder>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </StackPane>
            </VBox>

        </HBox>

        <!-- ── Totales ──────────────────────────────────────── -->
        <HBox alignment="CENTER_RIGHT" spacing="0">
            <HBox alignment="CENTER_LEFT" spacing="6" styleClass="total-box-ingresos">
                <Label style="-fx-font-size:13px; -fx-text-fill:#166534;" text="Total ingresos:" />
                <Label fx:id="lblTotalIngresos" styleClass="text-ingreso" style="-fx-font-size: 14px;" text="S/ 0.00" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="6" styleClass="total-box-descuentos">
                <Label style="-fx-font-size:13px; -fx-text-fill:#991B1B;" text="Total descuentos:" />
                <Label fx:id="lblTotalDescuentos" styleClass="text-descuento" style="-fx-font-size: 14px;" text="S/ 0.00" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="6" styleClass="total-box-neto">
                <Label style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#1E40AF;" text="Neto a pagar:" />
                <Label fx:id="lblNeto" styleClass="text-neto" style="-fx-font-size: 16px;" text="S/ 0.00" />
            </HBox>
        </HBox>

    </VBox>

</VBox>
