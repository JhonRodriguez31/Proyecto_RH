<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox fx:id="rootContainer"
      styleClass="app-shell"
      stylesheets="@../../css/layout.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.project.layout.UserLayoutController">

    <BorderPane
            VBox.vgrow="ALWAYS">
        <left>
            <VBox fx:id="sidebar"
                  prefWidth="280.0"
                  styleClass="sidebar">
                <padding>
                    <Insets top="20"
                            right="14"
                            bottom="14"
                            left="14"/>
                </padding>

                <Label text="RRHH Sistema"
                       styleClass="brand-title"/>
                <Label text="Empleado"
                       styleClass="role-badge role-user"/>

                <Region minHeight="14"/>

                <Button fx:id="btnPanel"
                        styleClass="menu-item">
                    <graphic>
                        <HBox alignment="CENTER_LEFT"
                              spacing="10"
                              styleClass="menu-content">
                            <FontIcon
                                    iconLiteral="mdi2v-view-dashboard-outline"
                                    styleClass="menu-icon"/>
                            <Label text="Mi Panel"
                                   styleClass="menu-text"/>
                        </HBox>
                    </graphic>
                </Button>
                <Button fx:id="btnDirectory"
                        styleClass="menu-item">
                    <graphic>
                        <HBox alignment="CENTER_LEFT"
                              spacing="10"
                              styleClass="menu-content">
                            <FontIcon
                                    iconLiteral="mdi2a-account-group-outline"
                                    styleClass="menu-icon"/>
                            <Label text="Directorio de Empleados"
                                   styleClass="menu-text"/>
                        </HBox>
                    </graphic>
                </Button>
                <Button fx:id="btnAttendance"
                        styleClass="menu-item">
                    <graphic>
                        <HBox alignment="CENTER_LEFT"
                              spacing="10"
                              styleClass="menu-content">
                            <FontIcon
                                    iconLiteral="mdi2c-calendar-check-outline"
                                    styleClass="menu-icon"/>
                            <Label text="Mis Asistencias"
                                   styleClass="menu-text"/>
                        </HBox>
                    </graphic>
                </Button>
                <Button fx:id="btnPayroll"
                        styleClass="menu-item">
                    <graphic>
                        <HBox alignment="CENTER_LEFT"
                              spacing="10"
                              styleClass="menu-content">
                            <FontIcon
                                    iconLiteral="mdi2c-cash-multiple"
                                    styleClass="menu-icon"/>
                            <Label text="Mi Planilla"
                                   styleClass="menu-text"/>
                        </HBox>
                    </graphic>
                </Button>
                <Button fx:id="btnVacation"
                        styleClass="menu-item">
                    <graphic>
                        <HBox alignment="CENTER_LEFT"
                              spacing="10"
                              styleClass="menu-content">
                            <FontIcon
                                    iconLiteral="mdi2b-beach"
                                    styleClass="menu-icon"/>
                            <Label text="Mis Vacaciones"
                                   styleClass="menu-text"/>
                        </HBox>
                    </graphic>
                </Button>
                <Button fx:id="btnBenefits"
                        styleClass="menu-item">
                    <graphic>
                        <HBox alignment="CENTER_LEFT"
                              spacing="10"
                              styleClass="menu-content">
                            <FontIcon
                                    iconLiteral="mdi2g-gift-outline"
                                    styleClass="menu-icon"/>
                            <Label text="Mis Beneficios"
                                   styleClass="menu-text"/>
                        </HBox>
                    </graphic>
                </Button>

                <Region VBox.vgrow="ALWAYS"/>

                <Region styleClass="sidebar-divider"
                        minHeight="1"
                        maxHeight="1"/>
                <Region minHeight="10"/>

                <HBox styleClass="user-card"
                      alignment="CENTER_LEFT"
                      spacing="12">
                    <StackPane
                            styleClass="user-avatar">
                        <Label text="U"
                               styleClass="avatar-initial"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="user"
                               styleClass="user-name"/>
                        <Label text="Empleado"
                               styleClass="user-role-text"/>
                    </VBox>
                </HBox>

                <Region minHeight="8"/>

                <Button text="Cerrar Sesión"
                        maxWidth="Infinity"
                        styleClass="logout-btn"
                        contentDisplay="LEFT">
                    <graphic>
                        <FontIcon
                                iconLiteral="mdi2l-logout"
                                styleClass="logout-icon"/>
                    </graphic>
                </Button>
            </VBox>
        </left>

        <center>
            <VBox spacing="14"
                  styleClass="main-area">
                <padding>
                    <Insets top="16"
                            right="18"
                            bottom="18"
                            left="18"/>
                </padding>

                <HBox alignment="CENTER_LEFT"
                      styleClass="topbar">
                    <Button fx:id="menuButton"
                            styleClass="icon-btn"
                            onAction="#toggleSidebar">
                        <graphic>
                            <FontIcon
                                    iconLiteral="mdi2m-menu"
                                    styleClass="topbar-icon"/>
                        </graphic>
                    </Button>
                    <Label fx:id="dateLabel"
                           text="martes, 21 de abril de 2026"
                           styleClass="date-label"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="themeButton"
                            styleClass="icon-btn"
                            onAction="#toggleTheme">
                        <graphic>
                            <FontIcon
                                    iconLiteral="mdi2w-weather-night"
                                    styleClass="topbar-icon"/>
                        </graphic>
                    </Button>
                </HBox>

                <StackPane
                        fx:id="contentHost"
                        styleClass="content-host"
                        VBox.vgrow="ALWAYS"/>
            </VBox>
        </center>
    </BorderPane>
</VBox>