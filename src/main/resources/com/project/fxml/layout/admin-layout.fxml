<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox fx:id="rootContainer" styleClass="app-shell" stylesheets="@../../css/theme.css, @../../css/layout.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.layout.AdminLayoutController">

    <BorderPane VBox.vgrow="ALWAYS">
        <left>
            <VBox fx:id="sidebar" prefWidth="280.0" styleClass="sidebar">
                <padding>
                    <Insets bottom="14" left="14" right="14" top="20" />
                </padding>

                <Label styleClass="brand-title" text="Planilla Core" />
                <Label styleClass="role-badge role-admin" text="Administrador" textFill="WHITE" />

                <Region minHeight="14" />

                <Button fx:id="btnDashboard" styleClass="menu-item">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="menu-content">
                            <FontIcon iconLiteral="mdi2v-view-dashboard-outline" styleClass="menu-icon" />
                            <Label styleClass="menu-text" text="Dashboard" />
                        </HBox>
                    </graphic>
                </Button>
                <Button fx:id="btnEmployees" styleClass="menu-item">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="menu-content">
                            <FontIcon iconLiteral="mdi2a-account-group-outline" styleClass="menu-icon" />
                            <Label styleClass="menu-text" text="Gestión de Empleados" />
                        </HBox>
                    </graphic>
                </Button>
                <Button fx:id="btnAttendance" styleClass="menu-item">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="menu-content">
                            <FontIcon iconLiteral="mdi2c-calendar-check-outline" styleClass="menu-icon" />
                            <Label styleClass="menu-text" text="Control de Asistencias" />
                        </HBox>
                    </graphic>
                </Button>
                <Button fx:id="btnPayroll" styleClass="menu-item">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="menu-content">
                            <FontIcon iconLiteral="mdi2c-cash-multiple" styleClass="menu-icon" />
                            <Label styleClass="menu-text" text="Gestión de Planilla" />
                        </HBox>
                    </graphic>
                </Button>
                <Button fx:id="btnVacation" styleClass="menu-item">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="menu-content">
                            <FontIcon iconLiteral="mdi2b-beach" styleClass="menu-icon" />
                            <Label styleClass="menu-text" text="Gestión de Vacaciones" />
                        </HBox>
                    </graphic>
                </Button>
                <Button fx:id="btnBenefits" styleClass="menu-item">
                    <graphic>
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="menu-content">
                            <FontIcon iconLiteral="mdi2g-gift-outline" styleClass="menu-icon" />
                            <Label styleClass="menu-text" text="Gestión de Beneficios" />
                        </HBox>
                    </graphic>
                </Button>
<!--                <Button fx:id="btnAudit"-->
<!--                        styleClass="menu-item">-->
<!--                    <graphic>-->
<!--                        <HBox alignment="CENTER_LEFT"-->
<!--                              spacing="10"-->
<!--                              styleClass="menu-content">-->
<!--                            <FontIcon-->
<!--                                    iconLiteral="mdi2h-history"-->
<!--                                    styleClass="menu-icon"/>-->
<!--                            <Label text="Historial de Auditoría"-->
<!--                                   styleClass="menu-text"/>-->
<!--                        </HBox>-->
<!--                    </graphic>-->
<!--                </Button>-->

                <Region VBox.vgrow="ALWAYS" />

                <Region maxHeight="1" minHeight="1" styleClass="sidebar-divider" />
                <Region minHeight="10" />

                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="usuario-card"
                      onMouseClicked="#navegarAPerfil" style="-fx-cursor: hand;">
                    <StackPane styleClass="usuario-avatar">
                        <Label fx:id="lblAvatarInitial" styleClass="avatar-initial" text="A" />
                        <ImageView fx:id="imgAvatar" fitHeight="36" fitWidth="36" />
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="lblUsuarioNombre" styleClass="usuario-name" text="admin" textFill="WHITE" />
                        <Label fx:id="lblUsuarioRol" styleClass="usuario-role-text" text="Administrador" textFill="WHITE" />
                    </VBox>
                </HBox>

                <Region minHeight="8" />

                <Button contentDisplay="LEFT" maxWidth="Infinity" onAction="#handleLogout" styleClass="logout-btn" text="Cerrar Sesión">
                    <graphic>
                        <FontIcon iconLiteral="mdi2l-logout" styleClass="logout-icon" />
                    </graphic>
                </Button>
            </VBox>
        </left>

        <center>
            <VBox spacing="14" styleClass="main-area">
                <padding>
                    <Insets bottom="18" left="18" right="18" top="16" />
                </padding>

                <HBox alignment="CENTER_LEFT" styleClass="topbar">
                    <Button fx:id="menuButton" onAction="#toggleSidebar" styleClass="icon-btn">
                        <graphic>
                            <FontIcon iconLiteral="mdi2m-menu" styleClass="topbar-icon" />
                        </graphic>
                    </Button>
                    <Label fx:id="dateLabel" styleClass="date-label" text="martes, 21 de abril de 2026" textFill="WHITE" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button styleClass="mode-pill" text="Modo Administrador" />
                    <Button fx:id="themeButton" onAction="#toggleTheme" styleClass="icon-btn">
                        <graphic>
                            <FontIcon iconLiteral="mdi2w-weather-night" styleClass="topbar-icon" />
                        </graphic>
                    </Button>
                </HBox>

                <StackPane fx:id="contentHost" styleClass="content-host" VBox.vgrow="ALWAYS" />
            </VBox>
        </center>
    </BorderPane>
</VBox>
