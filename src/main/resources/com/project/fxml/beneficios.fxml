<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" alignment="CENTER" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.project.controllers.BeneficioController" style="-fx-background-color: #f4f4f4;">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Gestión de Beneficios" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <Label text="Nombre del Beneficio:"/>
    <TextField fx:id="txtNombre" />

    <Label text="Monto:"/>
    <TextField fx:id="txtMonto" />

    <Button text="Guardar en Base de Datos" onAction="#guardarDatos"
            style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;"/>
</VBox>